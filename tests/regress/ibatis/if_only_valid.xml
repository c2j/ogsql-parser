<!-- description: Simple select with single if condition, valid flattened SQL -->
<!-- statements: 1 -->
<!-- namespace: test -->
<!-- flat-contains: SELECT, FROM users, WHERE -->
<!-- params: name -->
<!-- has-dynamic: true -->
<mapper namespace="test">
    <select id="findByName">
        SELECT * FROM users
        WHERE 1=1
        <if test="name != null">
            AND name = #{name}
        </if>
    </select>
</mapper>
