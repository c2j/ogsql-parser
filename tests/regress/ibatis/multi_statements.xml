<!-- description: Multiple statements in one mapper -->
<!-- statements: 2 -->
<!-- namespace: test -->
<!-- flat-contains: SELECT, FROM users, INSERT, INTO -->
<!-- params: name, email -->
<!-- has-dynamic: true -->
<mapper namespace="test">
    <select id="findAll">
        SELECT * FROM users
        WHERE 1=1
        <if test="name != null">
            AND name = #{name}
        </if>
    </select>
    <insert id="insertUser">
        INSERT INTO users (email) VALUES (#{email})
    </insert>
</mapper>
